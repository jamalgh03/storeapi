{
  "name": "udacity-storefront-api",
  "version": "1.0.0",
  "description": "Storefront Backend API for Udacity Project",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "npx tsx watch src/server.ts",
    "build": "tsc",
    "test": "ENV=test npx tsx src/tests/runTests.ts",
    "migrate:up": "db-migrate --env dev up",
    "migrate:down": "db-migrate --env dev down"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "postgresql",
    "express"
  ],
  "author": "Jamal Ghazawneh",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "db-migrate": "^0.11.14",
    "db-migrate-pg": "^1.5.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jasmine": "^5.1.4",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "jasmine": "^5.1.0",
    "jasmine-spec-reporter": "^7.0.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.5"
  }
}