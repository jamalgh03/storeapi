{
  "name": "udacity-storefront-api",
  "version": "1.0.0",
  "description": "Storefront Backend API for Udacity Project",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "npx tsx watch src/server.ts",
    "build": "tsc",
    "test": "ENV=test npx tsx src/tests/runTests.ts",
    "migrate:up": "db-migrate up",
    "migrate:down": "db-migrate down"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "postgresql",
    "express"
  ],
  "author": "Jamal Ghazawneh",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jasmine": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "jasmine": "^6.2.0",
    "jasmine-spec-reporter": "^7.0.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
